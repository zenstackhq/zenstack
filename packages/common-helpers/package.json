    "repository": {
        "type": "git",
        "url": "https://github.com/zenstackhq/zenstack"
    },
    "license": "MIT",
    "scripts": {
        "build": "tsc --noEmit && tsup-node",
        "watch": "tsup-node --watch",
        "lint": "eslint src --ext ts",
        "test": "vitest run",
        "pack": "pnpm pack"
    },
    "keywords": [],
