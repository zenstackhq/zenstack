datasource db {
    provider = 'sqlite'
}

model User {
    id    String  @id @default(cuid())
    email String  @unique
    name  String?
    posts Post[]
}

model Post {
    id       String  @id @default(cuid())
    title    String
    author   User?   @relation(fields: [authorId], references: [id])
    authorId String?
}

procedure getStats(): Int

mutation procedure sendNotification(message: String): Boolean
