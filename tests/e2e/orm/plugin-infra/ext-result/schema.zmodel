datasource db {
    provider = "sqlite"
}

model User {
    id    Int    @id @default(autoincrement())
    name  String
    posts Post[]
}

model Post {
    id       Int     @id @default(autoincrement())
    title    String
    content  String?
    author   User    @relation(fields: [authorId], references: [id])
    authorId Int
}
