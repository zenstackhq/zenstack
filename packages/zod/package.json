{
    "name": "@zenstackhq/zod",
    "displayName": "ZenStack Zod Integration",
    "description": "Automatically deriving Zod schemas from ZModel schemas",
    "version": "3.6.2",
    "type": "module",
    "author": {
        "name": "ZenStack Team",
        "email": "contact@zenstack.dev"
    },
    "homepage": "https://zenstack.dev",
    "repository": {
        "type": "git",
        "url": "https://github.com/zenstackhq/zenstack"
    },
    "license": "MIT",
    "scripts": {
        "build": "tsc --noEmit && tsdown",
        "watch": "tsdown --watch",
        "lint": "eslint src --ext ts",
        "test": "vitest run",
        "pack": "pnpm pack",
        "test:generate": "tsx ../../scripts/test-generate.ts ."
    },
    "keywords": [
        "zenstack",
        "zod"
    ],
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "dependencies": {
        "@zenstackhq/schema": "workspace:*",
        "decimal.js": "catalog:"
    },
    "devDependencies": {
        "@zenstackhq/eslint-config": "workspace:*",
        "@zenstackhq/tsdown-config": "workspace:*",
        "@zenstackhq/typescript-config": "workspace:*",
        "@zenstackhq/vitest-config": "workspace:*",
        "zod": "^4.1.0"
    },
    "peerDependencies": {
        "zod": "catalog:"
    },
    "funding": "https://github.com/sponsors/zenstackhq"
}
